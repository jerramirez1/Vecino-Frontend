# Copia este archivo a .env.test y completa los valores.

# Supabase de prueba (proyecto separado del de produccion)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# Dashboard > Project Settings > API > service_role (secret) — obligatorio para seed
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Alternativa al service role (opcional, desde .env.local):
# DATABASE_URL=postgresql://postgres:PASSWORD@db.TU-PROYECTO.supabase.co:5432/postgres

NEXT_PUBLIC_USE_MOCK_API=true
E2E_TEST_PASSWORD=12345678
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Usuarios creados por npm run db:setup:test:
#   e2e-test@example.com       (consumidor, E2E-01)
#   e2e-consumidor@example.com (consumidor, E2E-03)
#   e2e-vendedor@example.com   (vendedor, E2E-02)
